{
  "name": "roots-discourse-release-action",
  "version": "1.0.3",
  "description": "GitHub Action to create a Discourse post from a GitHub release",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "ncc build",
    "prepare": "ncc build -o dist --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run prepare && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roots/discourse-topic-github-release-action.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "Roots",
    "Discourse"
  ],
  "author": "Scott Walkinshaw <scott@roots.io>",
  "license": "MIT",
  "homepage": "https://github.com/roots",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/http-client": "^4.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.3.0"
  }
}
